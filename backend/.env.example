# ==============================
# Universal Sales ERP - Backend
# ==============================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/us_erp?schema=public"

# JWT secret key – use a long, random string in production
JWT_SECRET="change-me-to-a-long-random-secret"

# Refresh Token secret key
REFRESH_TOKEN_SECRET="change-me-to-another-long-random-secret"

# Port the Express server listens on
PORT=5000
