              "raw": "{\n  \"customerId\": 1,\n  \"validTill\": \"2026-09-01T00:00:00.000Z\",\n  \"remarks\": \"Test quotation\",\n  \"discount\": 10,\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 5, \"unitPrice\": 29.99 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get Quotation by ID",
          "request": {
