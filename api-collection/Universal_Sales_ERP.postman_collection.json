            "url": "{{baseUrl}}/products/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/products/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wireless Ergonomic Mouse Pro\",\n  \"sku\": \"SKU-ELC-001\",\n  \"categoryId\": 1,\n  \"hsnCode\": \"8471\",\n  \"purchasePrice\": 18,\n  \"sellingPrice\": 34.99,\n  \"gstPercentage\": 18,\n  \"unit\": \"PCS\",\n  \"currentStock\": 50,\n  \"minimumStock\": 10,\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
